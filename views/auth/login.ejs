<%- include('../partials/head') %>
<%- include('../partials/nav') %>


<body class="min-h-screen bg-slate-100 text-slate-900">
        <header class="bg-blue-600 text-white py-6 px-4 text-center">
            <h1 class="m-0 text-xl font-semibold">Login</h1>
        </header>
        <main class="container mx-auto mt-8 p-10">
            <section class="w-full max-w-xl bg-white p-8 rounded-3xl shadow-[0_6px_18px_rgba(32,33,36,0.08)]">
                <h2 class="text-3xl font-bold mb-6 text-center text-slate-900">Login with your info</h2>
                
                <form action="/login" method="POST" class="max-w-md mx-auto">
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email</label>

                    <%- include('../partials/errors') %>

                    <input id="email" type="email" name="email" placeholder="Email" required 
                    value="<%= oldInput && oldInput.email ? oldInput.email : '' %>"
                    class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />

                    <label for="password" class="block text-sm font-medium text-slate-700 mt-4 mb-2">Password</label>
                    <input id="password" type="password" name="password" placeholder="Enter your password" required class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />

                    <div class="mt-6">
                        <button type="submit" class="w-full rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-300">Login</button>
                    </div>
                </form>
            </section>
        </main>
    </body>
</html>