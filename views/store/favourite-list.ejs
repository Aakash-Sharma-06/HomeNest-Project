<%- include('../partials/head') %>
<%- include('../partials/nav') %>



<body>
    <header class="header">
        <h1 class="page-title">Here is your favourite home</h1>

        <div class="card-grid">
            <% favouriteHome.forEach(home => { %>
                <div class="home-card">
                    <h2><%= home.houseName %></h2>

                    <p><strong>Location:</strong> <%= home.location %></p>
                    <p><strong>Price:</strong> <%= home.price %></p>
                    <p><strong>Rating:</strong> <%= home.rating %></p>

                    <form
                        class="remove-form"
                        action="/favourites/delete/<%= home._id %>"
                        method="POST"
                    >
                        <button type="submit" class="remove-btn">
                            Remove from Favourites
                        </button>
                    </form>
                </div>
            <% }) %>
        </div>
    </header>
</body>

</html>