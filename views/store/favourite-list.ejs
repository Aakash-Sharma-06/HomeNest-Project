<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<body class="bg-gray-100 text-gray-800 min-h-screen">
    <header class="max-w-6xl mx-auto px-4 py-8">
        <h1 class="text-3xl font-semibold mb-6">My Favourites</h1>
        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <% if (!favouriteHome || favouriteHome.length === 0) { %>
                <p class="text-gray-600 col-span-full">You have no favourite homes yet. Browse <a href="/homes" class="text-blue-600 font-semibold hover:underline">homes</a> to add some.</p>
            <% } else { %>
                <% favouriteHome.forEach(home => { %>
                    <div class="bg-white rounded-lg shadow overflow-hidden flex flex-col">
                        <img class="w-full h-48 object-cover" src="<%= home.photo %>" alt="<%= home.houseName %>">
                        <div class="p-4 flex-1 flex flex-col">
                            <h2 class="text-xl font-medium mb-2"><%= home.houseName %></h2>
                            <p class="text-sm text-gray-600"><strong>Location:</strong> <%= home.location %></p>
                            <p class="text-sm text-gray-600"><strong>Price:</strong> $<%= home.price %></p>
                            <p class="text-sm text-yellow-500 mt-1"><strong>Rating:</strong> <%= home.rating %> / 5</p>
                            <div class="flex flex-wrap gap-2 mt-4">
                                <a href="/homes/<%= home._id %>" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 transition-colors">
                                    Details
                                </a>
                                <form action="/favourites/delete/<%= home._id %>" method="POST" class="inline">
                                    <button type="submit" class="px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold hover:bg-red-600 transition-colors">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </header>
</body>

</html>
