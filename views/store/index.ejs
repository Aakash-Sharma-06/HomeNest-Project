<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">


<body class="bg-gray-100 text-gray-800">
    <header class="max-w-6xl mx-auto px-4 py-8">
        <h1 class="text-3xl font-semibold mb-6">
            <%= pageTitle || 'Registered Homes' %>
        </h1>
        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <% if (registerHome.length === 0) { %>
                <p class="text-gray-600">No homes registered yet. Add one to get started.</p>
            <% } else { %>
                <% registerHome.forEach(home => { %>
                    <div class="bg-white rounded-lg shadow overflow-hidden">
                        <img class="w-full h-48 object-cover" src="<%= home.photo %>" alt="<%= home.houseName %>">
                        <div class="p-4">
                            <h2 class="text-xl font-medium mb-2"><%= home.houseName %></h2>
                            <p class="text-sm text-gray-600"><strong>Location:</strong> <%= home.location %></p>
                            <p class="text-sm text-gray-600"><strong>Price:</strong> <%= home.price %></p>
                            <p class="text-sm text-yellow-500 mt-2"><strong>Rating:</strong> <%= home.rating %> / 5</p>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </header>
    <main class="max-w-6xl mx-auto px-4 pb-12">
        <% if (isLoggedIn && user && user.usertype === 'host') { %>
        <a class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded" href="/host/add-home">Add home</a>
        <% } %>
    </main>
</body>

</html>