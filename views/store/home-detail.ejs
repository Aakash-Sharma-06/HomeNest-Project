<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<body class="bg-gray-100 text-gray-900 min-h-screen">
  <header class="py-9 px-4 text-center">
    <h1 class="text-2xl text-red-700 capitalize tracking-wide mb-4">Here is your detail</h1>
    <div class="flex justify-center px-4">
      <div class="bg-white border border-gray-200 rounded-2xl shadow-lg max-w-md w-full p-7">
        <img class="w-full h-56 object-cover rounded-lg mb-4" src="<%= home.photo %>" alt="<%= home.houseName %>">
        <h2 class="text-xl font-semibold mb-2"><%= home.houseName %></h2>
        <p class="text-sm text-gray-700 mb-2"><strong class="text-gray-900">Location:</strong> <%= home.location %></p>
        <p class="text-sm text-gray-700 mb-2"><strong class="text-gray-900">Price:</strong> <%= home.price %></p>
        <p class="text-sm text-gray-700"><strong class="text-gray-900">Rating:</strong> <%= home.rating %></p>
        <div class="flex justify-center gap-3 mt-6">
          <% if (isLoggedIn && user && user.usertype === 'guest') { %>
          <%- include('../partials/favourites', { home: home }) %>
          <% } %>
          <a href="/homes" class="px-4 py-2 rounded-lg bg-gray-200 text-gray-800 text-sm font-semibold hover:bg-gray-300 transition-colors">Back to Homes</a>
        </div>
      </div>
    </div>
  </header>
</body>

</html>