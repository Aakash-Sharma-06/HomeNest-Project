<%- include('../partials/head') %>
<%- include('../partials/nav') %>


<body>
        <header>
            <h1><%=editing ? "Edit" : "Add" %> your home</h1>
        </header>
        <main>
            <section class="form-card">
                <form action="/host/<%= editing? "edit-home" : "add-home" %>" enctype="multipart/form-data" method="POST">

                    <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />

                    <label for="houseName">House name</label>
                    <input id="houseName" type="text" name="houseName" value="<%= editing ? home.houseName : '' %>" placeholder="Enter name of your house" required />

                    <label for="location">Location</label>
                    <input id="location" type="text" name="location" value="<%= editing ? home.location : '' %>" placeholder="Enter location of your house" required />

                    <label for="price">Price per night (USD)</label>
                    <input id="price" type="number" name="price" value="<%= editing ? home.price : '' %>" placeholder="Enter price per night" min="0" step="0.01" required />

                    <label for="rating">Rating</label>
                    <input id="rating" type="number" name="rating" value="<%= editing ? home.rating : '' %>" placeholder="Enter rating out of 5" min="0" max="5" step="0.1" required />

                    <label for="photo">Photo</label>
                    <input id="photo" type="file" accept="image/jpg, image/jpeg, image/png" name="photo" required />

                    <label for="description">Describe your home</label>
                    <textarea id="description" name="description" placeholder="Enter description for your home" required><%= editing ? home.description : '' %></textarea>

                    <div class="actions">
                        <button type="submit" class="btn"><%= editing ? "Update" : "Add" %> Home</button>
                    </div>
                </form>
            </section>
        </main>
        

        <style>
            body { font-family: Arial, sans-serif; background:#f5f7fb; color:#263238; margin:0; padding:0; }
            header { background:#1976d2; color:white; padding:20px 16px; text-align:center; }
            h1 { margin:0; font-size:1.4rem; }
            main { display:flex; justify-content:center; padding:40px 16px; }
            .form-card { background:white; padding:24px; border-radius:8px; box-shadow:0 6px 18px rgba(32,33,36,0.08); width:100%; max-width:420px; }
            label { display:block; font-size:0.9rem; margin-top:12px; margin-bottom:6px; }
            input[type="text"], input[type="number"], input[type="url"] { width:100%; padding:10px 12px; border:1px solid #cfd8dc; border-radius:6px; font-size:1rem; }
            .actions { margin-top:18px; text-align:right; }
            .btn { background:#1976d2; color:white; border:none; padding:10px 16px; border-radius:6px; cursor:pointer; font-size:1rem; }
            .btn:hover { background:#1565c0; }
        </style>
    </body>
</html>